@page "/"
@using System.ComponentModel
@using System.Text
@using System.Text.Json
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.JSInterop
@using UglyToad.PdfPig
@using TechYugaAI.Models
@using TechYugaAI.Services
@inject IChatClient ChatClient
@inject SemanticSearch Search
@inject CvDraftState CvDraftState
@inject CvTemplateRegistry TemplateRegistry
@inject TechYugaAgentTools AgentTools
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>TechYugaAI - @currentMode.ToString()</PageTitle>

@* --- COMMON UI TOOLBAR --- *@
<div class="techyuga-nav d-flex gap-2 p-3 bg-light border-bottom">
    <button class="btn @(currentMode == TechYugaMode.General ? "btn-primary" : "btn-outline-primary")" @onclick="() => SwitchMode(TechYugaMode.General)">General Chat</button>
    <button class="btn @(currentMode == TechYugaMode.CVCreator ? "btn-primary" : "btn-outline-primary")" @onclick="() => SwitchMode(TechYugaMode.CVCreator)">CV Creator</button>
    <button class="btn @(currentMode == TechYugaMode.BidMaker ? "btn-primary" : "btn-outline-primary")" @onclick="() => SwitchMode(TechYugaMode.BidMaker)">Bid Maker</button>
    <button class="btn @(currentMode == TechYugaMode.ProjectProposal ? "btn-primary" : "btn-outline-primary")" @onclick="() => SwitchMode(TechYugaMode.ProjectProposal)">Proposals</button>
</div>

@if (currentMode != TechYugaMode.CVCreator)
{
    <ChatHeader OnNewChat="@NewChatAsync" />
}

@if (currentMode == TechYugaMode.CVCreator)
{
    <div class="cv-toolbar page-width">
        <div class="cv-tab-group">
            <button class="cv-tab @(currentCvTab == CvWorkflowTab.Guided ? "active" : "")" @onclick="() => SwitchCvTab(CvWorkflowTab.Guided)">Guided CV</button>
            <button class="cv-tab @(currentCvTab == CvWorkflowTab.Prompt ? "active" : "")" @onclick="() => SwitchCvTab(CvWorkflowTab.Prompt)">Prompt + Job Description</button>
            <button class="cv-tab @(currentCvTab == CvWorkflowTab.Upload ? "active" : "")" @onclick="() => SwitchCvTab(CvWorkflowTab.Upload)">Resume Upload</button>
        </div>
        <div class="cv-template-badge">
            Template: <strong>@TemplateRegistry.Get(CvDraftState.SelectedTemplateId).Name</strong>
        </div>
    </div>

    <div class="cv-shell">
        <div class="cv-left">
            @if (currentCvTab == CvWorkflowTab.Prompt)
            {
                <div class="cv-prompt-card">
                    <div class="cv-steps">
                        <div class="cv-step">1. Prompt</div>
                        <div class="cv-step">2. Choose Template</div>
                        <div class="cv-step">3. Generate CV</div>
                    </div>
                    <div class="cv-prompt-title">Prompt + Job Description</div>
                    <p class="cv-hint">Provide a single prompt that includes job description, skills, experience required, and expectations. The assistant will generate a complete, ATS-optimized resume.</p>

                    @if (PromptWarnings.Count > 0)
                    {
                        <div class="cv-alert">
                            <strong>Before generating:</strong>
                            <ul>
                                @foreach (var warning in PromptWarnings)
                                {
                                    <li>@warning</li>
                                }
                            </ul>
                        </div>
                    }

                    <label class="cv-field-label">Prompt *</label>
                    <textarea class="cv-textarea" @bind="hrJobDescription" @bind:event="oninput" rows="6" placeholder="Include job description, skills, experience required, and any other expectations here."></textarea>
                    <div class="cv-prompt-actions">
                        <button class="btn btn-primary" @onclick="GenerateFromPromptAsync">Generate CV</button>
                    </div>
                    <div class="cv-template-inline">
                        <div class="cv-field-label">Choose a template *</div>
                        <CvTemplatePicker Templates="@TemplateRegistry.Templates"
                                          SelectedTemplateId="@CvDraftState.SelectedTemplateId"
                                          SelectedTemplateIdChanged="@OnTemplateSelected" />
                    </div>
                </div>
            }
            else if (currentCvTab == CvWorkflowTab.Upload)
            {
                <div class="cv-prompt-card">
                    <div class="cv-steps">
                        <div class="cv-step">1. Upload Resume</div>
                        <div class="cv-step">2. Prompt + JD</div>
                        <div class="cv-step">3. Choose Template</div>
                        <div class="cv-step">4. Generate CV</div>
                    </div>
                    <div class="cv-prompt-title">Resume Upgrade (PDF)</div>
                    <p class="cv-hint">Upload an existing resume PDF and provide a single prompt with job description, skills, experience required, and expectations. The assistant will rewrite and optimize the CV.</p>

                    @if (!string.IsNullOrWhiteSpace(uploadError))
                    {
                        <div class="cv-alert cv-alert-error">@uploadError</div>
                    }

                    @if (UploadWarnings.Count > 0)
                    {
                        <div class="cv-alert">
                            <strong>Before generating:</strong>
                            <ul>
                                @foreach (var warning in UploadWarnings)
                                {
                                    <li>@warning</li>
                                }
                            </ul>
                        </div>
                    }

                    <label class="cv-field-label">Upload Resume PDF *</label>
                    <div class="cv-upload-row">
                        <label class="cv-upload-btn" for="resumeUploadInput">
                            <span>Upload Resume File</span>
                        </label>
                        <InputFile id="resumeUploadInput" OnChange="HandleResumeUploadAsync" accept=".pdf" class="cv-file-input" style="display:none" />
                        <div class="cv-upload-name @(string.IsNullOrWhiteSpace(uploadedResumeFileName) ? "muted" : "selected")">
                            @(!string.IsNullOrWhiteSpace(uploadedResumeFileName) ? uploadedResumeFileName : "No file selected")
                        </div>
                    </div>
                    @if (uploadInProgress)
                    {
                        <div class="cv-upload-status">Extracting text from PDF...</div>
                    }
                    @if (!string.IsNullOrWhiteSpace(uploadedResumeFileName))
                    {
                        <div class="cv-upload-status">Uploaded: @uploadedResumeFileName (@(uploadedResumeText?.Length ?? 0) characters extracted)</div>
                    }

                    <label class="cv-field-label">Prompt *</label>
                    <textarea class="cv-textarea" @bind="uploadJobDescription" @bind:event="oninput" rows="6" placeholder="Include job description, skills, experience required, and any other expectations here."></textarea>
                    <div class="cv-prompt-actions">
                        <button class="btn btn-primary" @onclick="GenerateFromUploadAsync">Improve Resume</button>
                    </div>
                    <div class="cv-template-inline">
                        <div class="cv-field-label">Choose a template *</div>
                        <CvTemplatePicker Templates="@TemplateRegistry.Templates"
                                          SelectedTemplateId="@CvDraftState.SelectedTemplateId"
                                          SelectedTemplateIdChanged="@OnTemplateSelected" />
                    </div>
                </div>
            }
            else
            {
                <div class="cv-guide-card">
                    <div class="cv-guide-title">Guided CV Builder</div>
                    <p>Share your details in chat. The assistant will collect and structure your resume using AI only.</p>
                    <CvTemplatePicker Templates="@TemplateRegistry.Templates"
                                      SelectedTemplateId="@CvDraftState.SelectedTemplateId"
                                      SelectedTemplateIdChanged="@OnTemplateSelected" />
                </div>
            }

            <ChatMessageList Messages="@messages" InProgressMessage="@currentResponseMessage">
                <NoMessagesContent>
                    <div class="cv-empty-chat">
                        <h3>Start building your CV</h3>
                        <p>Tell the assistant about your experience, skills, projects, or education.</p>
                    </div>
                </NoMessagesContent>
            </ChatMessageList>

            <div class="chat-container">
                <ChatSuggestions OnSelected="@AddUserMessageFromInputAsync" @ref="@chatSuggestions" />
                <ChatInput OnSend="@AddUserMessageFromInputAsync" @ref="@chatInput" />
            </div>
        </div>

        <div class="cv-right">
            <div class="cv-preview-header">
                <div>
                    <h3>Live Preview</h3>
                    <div class="cv-preview-sub">Template: @TemplateRegistry.Get(CvDraftState.SelectedTemplateId).Name</div>
                </div>
                @if (CvDraftState.LastGeneratedPdfUrl is not null)
                {
                    <span class="cv-preview-status">PDF Ready</span>
                }
            </div>

            <div class="cv-preview-body">
                <div class="cv-preview-canvas">
                    <CvTemplateRenderer Draft="@CvDraftState.Draft" TemplateId="@CvDraftState.SelectedTemplateId" />
                </div>
            </div>

            <div class="cv-preview-actions">
                @if (CvDraftState.LastGeneratedPdfUrl is not null)
                {
                    <a class="btn btn-outline-primary" href="@CvDraftState.LastGeneratedPdfUrl" target="_blank">View PDF</a>
                    <a class="btn btn-primary" href="@CvDraftState.LastGeneratedPdfUrl" download="@CvDraftState.LastGeneratedPdfFileName">Download PDF</a>
                    @if (currentCvTab != CvWorkflowTab.Guided)
                    {
                        <button class="btn btn-outline-secondary" @onclick="() => SwitchCvTab(CvWorkflowTab.Guided)">Update CV (Guided)</button>
                    }
                }
                else
                {
                    <button class="btn btn-primary" @onclick="RequestPdfGenerationAsync">Generate PDF with Assistant</button>
                }
            </div>
        </div>
    </div>
}
else
{
    <ChatMessageList Messages="@messages" InProgressMessage="@currentResponseMessage">
        <NoMessagesContent>
            <div class="p-4 text-center">
                <h3>Welcome to TechYugaAI</h3>
                <p>Current Mode: <strong>@currentMode</strong></p>
                <p>Select a tool above to start a specialized session.</p>
            </div>
        </NoMessagesContent>
    </ChatMessageList>

    <div class="chat-container">
        <ChatSuggestions OnSelected="@AddUserMessageFromInputAsync" @ref="@chatSuggestions" />
        <ChatInput OnSend="@AddUserMessageFromInputAsync" @ref="@chatInput" />
    </div>
}

@code {
    private enum CvWorkflowTab
    {
        Guided,
        Prompt,
        Upload
    }

    private const long MaxUploadBytes = 10 * 1024 * 1024;
    private const int MaxResumeChars = 12000;
    private const int MaxResumePages = 6;

    private TechYugaMode currentMode = TechYugaMode.General;
    private CvWorkflowTab currentCvTab = CvWorkflowTab.Guided;
    private string? hrJobDescription;
    private string? uploadJobDescription;
    private string? uploadedResumeText;
    private string? uploadedResumeFileName;
    private string? uploadError;
    private bool uploadInProgress;
    private bool promptAttempted;
    private bool uploadAttempted;
    private bool templateSelectionTouched;

    private int statefulMessageCount;
    private readonly ChatOptions chatOptions = new();
    private static readonly JsonSerializerOptions DraftJsonOptions = new()
    {
        PropertyNamingPolicy = JsonNamingPolicy.CamelCase,
        DefaultIgnoreCondition = System.Text.Json.Serialization.JsonIgnoreCondition.WhenWritingNull
    };
    private readonly List<ChatMessage> messages = new();
    private CancellationTokenSource? currentResponseCancellation;
    private ChatMessage? currentResponseMessage;
    private ChatInput? chatInput;
    private ChatSuggestions? chatSuggestions;

    protected override void OnInitialized()
    {
        InitializeTools();
        CvDraftState.OnChange += HandleDraftChange;
        messages.Add(new(ChatRole.System, GetSystemPrompt()));
    }

    private void HandleDraftChange() => InvokeAsync(StateHasChanged);

    private string GetSystemPrompt()
    {
        if (currentMode == TechYugaMode.CVCreator)
        {
            var templateList = string.Join(", ", TemplateRegistry.Templates.Select(t => $"{t.Id} ({t.Name})"));
            var jsonSchema = """
                Use UpdateCvDraft with JSON:
                - Use strings for all scalar values (including dates and years of experience).
                {
                  "fullName": "",
                  "headline": "",
                  "summary": "",
                  "roleTarget": "",
                  "yearsOfExperience": "",
                  "contact": { "email": "", "phone": "", "location": "", "linkedin": "", "portfolio": "", "website": "" },
                  "skills": [],
                  "skillGroups": [ { "name": "", "items": [] } ],
                  "experiences": [ { "title": "", "company": "", "location": "", "employmentType": "", "startDate": "", "endDate": "", "highlights": [], "technologies": [] } ],
                  "education": [ { "degree": "", "institution": "", "location": "", "startDate": "", "endDate": "", "details": [] } ],
                  "projects": [ { "name": "", "role": "", "description": "", "link": "", "highlights": [], "technologies": [] } ],
                  "certifications": [ { "name": "", "issuer": "", "date": "" } ],
                  "additionalNotes": []
                }
                """;

            if (currentCvTab == CvWorkflowTab.Guided)
            {
                return $"""
                    You are the TechYuga CV Agent (Guided Mode). Collect CV details using AI-only chat prompts.
                    Ask concise follow-up questions when information is missing. Support freshers (focus on projects/skills)
                    and experienced professionals (focus on impact and work history). Keep the resume ATS-optimized.
                    Available templates: {templateList}. Use the selected template ID when generating PDFs.
                    {jsonSchema}
                    Always call UpdateCvDraft after every user response that provides new information.
                    Provide a complete JSON draft that retains any previously known data. Do not clear fields unless instructed.
                    If the user asks to remove or clear a section, set the corresponding string to "" or array to [].
                    When the user asks to generate a PDF, call GenerateCVDoc with templateId and the full cvJson draft.
                    """;
            }

            if (currentCvTab == CvWorkflowTab.Upload)
            {
                return $"""
                    You are the TechYuga CV Enhancer (Resume Upload Mode). You will receive resume text extracted from a PDF,
                    plus a prompt containing job description, skills, experience required, and expectations. Rewrite and optimize the resume for ATS,
                    ensure strong impact statements, and fill missing sections if possible without inventing facts.
                    Available templates: {templateList}. Use the selected template ID when generating PDFs.
                    {jsonSchema}
                    First call UpdateCvDraft with the full JSON draft. Then respond with a short summary and ask for edits.
                    When the user requests the final PDF, call GenerateCVDoc with templateId and the full cvJson draft.
                    If the user indicates no experience is required, do not include any Experience entries and set yearsOfExperience to "0".
                    If the user asks to remove or clear a section, set the corresponding string to "" or array to [].
                    """;
            }

            return $"""
                You are the TechYuga CV Generator (Prompt Mode). Use the provided prompt (job description, skills, experience required, expectations)
                to generate a complete, ATS-optimized, one-page resume.
                Populate all relevant sections without inventing facts.
                Available templates: {templateList}. Use the selected template ID when generating PDFs.
                {jsonSchema}
                First call UpdateCvDraft with the full JSON draft. Then respond with a short summary and ask if edits are needed.
                When the user requests the final PDF, call GenerateCVDoc with templateId and the full cvJson draft.
                If the user indicates no experience is required, do not include any Experience entries and set yearsOfExperience to "0".
                If the user asks to remove or clear a section, set the corresponding string to "" or array to [].
                """;
        }

        return currentMode switch
        {
            TechYugaMode.BidMaker => "You are the TechYuga Bid Specialist. Help users estimate costs. Use CalculateBid for any pricing logic.",
            TechYugaMode.ProjectProposal => "You are the TechYuga Proposal Architect. Draft formal project scopes and timelines.",
            _ => "You are TechYugaAI, a professional assistant using RAG to answer questions."
        };
    }

    private void InitializeTools()
    {
        chatOptions.Tools =
        [
            AIFunctionFactory.Create(LoadDocumentsAsync),
            AIFunctionFactory.Create(SearchAsync),
            AIFunctionFactory.Create(AgentTools.UpdateCvDraft),
            AIFunctionFactory.Create(AgentTools.GenerateCVDoc),
            AIFunctionFactory.Create(AgentTools.CalculateBid)
        ];
    }

    private async Task SwitchMode(TechYugaMode newMode)
    {
        currentMode = newMode;
        await ResetConversationAsync();
    }

    private async Task SwitchCvTab(CvWorkflowTab tab)
    {
        currentCvTab = tab;
        promptAttempted = false;
        uploadAttempted = false;
        uploadError = null;
        await ResetConversationAsync();
    }

    private void OnTemplateSelected(string templateId)
    {
        templateSelectionTouched = true;
        CvDraftState.SetTemplate(templateId);
    }

    private async Task GenerateFromPromptAsync()
    {
        try
        {
            promptAttempted = true;
            if (!IsPromptReady)
            {
                await ShowValidationAlertAsync(BuildPromptWarnings());
                return;
            }

            var template = TemplateRegistry.Get(CvDraftState.SelectedTemplateId);
            var builder = new StringBuilder();
            builder.AppendLine("Generate a professional, ATS-optimized resume using the following inputs.");
            builder.AppendLine();
            builder.AppendLine("Prompt (job description + skills + experience + expectations):");
            builder.AppendLine(hrJobDescription!.Trim());
            builder.AppendLine();
            builder.AppendLine($"Template preference: {template.Name} ({template.Id}).");
            builder.AppendLine("Return structured data via UpdateCvDraft.");
            builder.AppendLine("Important: Do not invent experience if the prompt says no experience required.");
            builder.AppendLine("If no experience is required, set yearsOfExperience to \"0\" and keep experiences empty.");
            if (IndicatesNoExperience(hrJobDescription))
            {
                builder.AppendLine("Constraint: No professional experience required. Do not include any Experience entries.");
            }
            if (HasExistingDraftData())
            {
                builder.AppendLine("Update the existing draft with these changes and replace any conflicting sections.");
            }

            var displayMessage = new ChatMessage(ChatRole.User, "Generate resume/CV from the provided prompt.");
            var aiMessage = new ChatMessage(ChatRole.User, builder.ToString());
            await AddUserMessageAsync(
                displayMessage,
                aiUserMessage: aiMessage,
                forceFreshContext: true,
                suppressAssistantText: true,
                inProgressLabel: "Generating resume/CV...",
                completionLabel: "Resume/CV generated. Preview updated.");
        }
        catch (Exception ex)
        {
            AddLocalErrorMessage(ex);
        }
    }

    private async Task GenerateFromUploadAsync()
    {
        try
        {
            uploadAttempted = true;
            if (!IsUploadReady)
            {
                await ShowValidationAlertAsync(BuildUploadWarnings());
                return;
            }

            var template = TemplateRegistry.Get(CvDraftState.SelectedTemplateId);
            var builder = new StringBuilder();
            builder.AppendLine("Improve and rewrite this resume based on the target role and job description.");
            builder.AppendLine();
            builder.AppendLine("Prompt (job description + skills + experience + expectations):");
            builder.AppendLine(uploadJobDescription!.Trim());
            builder.AppendLine();
            builder.AppendLine("Resume Text (from PDF):");
            builder.AppendLine(uploadedResumeText!.Trim());
            builder.AppendLine();
            builder.AppendLine($"Template preference: {template.Name} ({template.Id}).");
            builder.AppendLine("Return structured data via UpdateCvDraft.");
            builder.AppendLine("Important: Do not invent experience if the prompt says no experience required.");
            builder.AppendLine("If no experience is required, set yearsOfExperience to \"0\" and keep experiences empty.");
            if (IndicatesNoExperience(uploadJobDescription))
            {
                builder.AppendLine("Constraint: No professional experience required. Do not include any Experience entries.");
            }
            if (HasExistingDraftData())
            {
                builder.AppendLine("Update the existing draft with these changes and replace any conflicting sections.");
            }

            var displayMessage = new ChatMessage(ChatRole.User, "Improve the resume using the uploaded PDF and prompt.");
            var aiMessage = new ChatMessage(ChatRole.User, builder.ToString());
            await AddUserMessageAsync(
                displayMessage,
                aiUserMessage: aiMessage,
                forceFreshContext: true,
                suppressAssistantText: true,
                inProgressLabel: "Generating resume/CV...",
                completionLabel: "Resume/CV generated. Preview updated.");
        }
        catch (Exception ex)
        {
            AddLocalErrorMessage(ex);
        }
    }

        private async Task RequestPdfGenerationAsync()
        {
            try
            {
                var template = TemplateRegistry.Get(CvDraftState.SelectedTemplateId);
                var draftJson = JsonSerializer.Serialize(CvDraftState.Draft, DraftJsonOptions);
                var message = $"Please generate the final CV PDF using template {template.Name} ({template.Id}). Use GenerateCVDoc with the full cvJson draft.\ncvJson:\n{draftJson}";
                var displayMessage = new ChatMessage(ChatRole.User, "Generate the final CV PDF.");
                var aiMessage = new ChatMessage(ChatRole.User, message);
                await AddUserMessageAsync(
                    displayMessage,
                    aiUserMessage: aiMessage,
                    forceFreshContext: true,
                    suppressAssistantText: true,
                    inProgressLabel: "Generating final CV PDF...",
                    completionLabel: "PDF generation completed. Use View/Download if available.");
            }
            catch (Exception ex)
            {
                AddLocalErrorMessage(ex);
            }
        }

    private async Task HandleResumeUploadAsync(InputFileChangeEventArgs args)
    {
        uploadError = null;
        uploadedResumeText = null;
        uploadedResumeFileName = null;
        uploadInProgress = false;

        var file = args.File;
        if (file is null)
        {
            uploadError = "Please choose a PDF file.";
            return;
        }

        if (!file.Name.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase))
        {
            uploadError = "Only PDF files are supported.";
            return;
        }

        if (file.Size > MaxUploadBytes)
        {
            uploadError = $"Please upload a PDF smaller than {MaxUploadBytes / (1024 * 1024)} MB.";
            return;
        }

        uploadedResumeFileName = file.Name;

        try
        {
            uploadInProgress = true;
            await InvokeAsync(StateHasChanged);

            await using var stream = file.OpenReadStream(MaxUploadBytes);
            using var buffer = new MemoryStream();
            await stream.CopyToAsync(buffer);
            buffer.Position = 0;

            var extracted = await Task.Run(() => ExtractTextFromPdf(buffer));
            if (string.IsNullOrWhiteSpace(extracted))
            {
                uploadError = "We could not extract readable text from that PDF. Try a different file.";
                return;
            }

            uploadedResumeText = TrimResumeText(extracted, MaxResumeChars);
        }
        catch (Exception ex)
        {
            uploadError = $"Failed to read the PDF: {ex.Message}";
        }
        finally
        {
            uploadInProgress = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private static string ExtractTextFromPdf(Stream pdfStream)
    {
        if (pdfStream.CanSeek)
        {
            pdfStream.Position = 0;
        }

        using var document = PdfDocument.Open(pdfStream);
        var builder = new StringBuilder();
        var pageCount = 0;
        foreach (var page in document.GetPages())
        {
            pageCount++;
            if (pageCount > MaxResumePages)
            {
                break;
            }
            var text = page.Text;
            if (!string.IsNullOrWhiteSpace(text))
            {
                builder.AppendLine(text.Trim());
                builder.AppendLine();
            }

            if (builder.Length >= MaxResumeChars)
            {
                break;
            }
        }

        return builder.ToString().Trim();
    }

    private static string TrimResumeText(string text, int maxChars)
    {
        if (string.IsNullOrWhiteSpace(text))
        {
            return string.Empty;
        }

        return text.Length <= maxChars ? text : text[..maxChars];
    }

    private async Task NewChatAsync()
    {
        if (currentMode == TechYugaMode.CVCreator)
        {
            CvDraftState.Reset();
            hrJobDescription = null;
            uploadJobDescription = null;
            uploadedResumeText = null;
            uploadedResumeFileName = null;
            uploadError = null;
            promptAttempted = false;
            uploadAttempted = false;
            templateSelectionTouched = false;
        }

        await ResetConversationAsync();
    }

    private async Task AddUserMessageAsync(
        ChatMessage userMessage,
        ChatMessage? aiUserMessage = null,
        bool forceFreshContext = false,
        bool suppressAssistantText = false,
        string? inProgressLabel = null,
        string? completionLabel = null)
    {
        try
        {
            await AddUserMessageCoreAsync(userMessage, aiUserMessage, forceFreshContext, suppressAssistantText, inProgressLabel, completionLabel);
        }
        catch (Exception ex)
        {
            currentResponseCancellation?.Cancel();
            currentResponseCancellation = null;
            currentResponseMessage = null;
            messages.Add(new(ChatRole.Assistant, $"[AI connection error: {ex.Message}]"));
            chatSuggestions?.Update(messages);
        }
    }

    private Task AddUserMessageFromInputAsync(ChatMessage userMessage)
        => AddUserMessageAsync(userMessage);

    private async Task AddUserMessageCoreAsync(
        ChatMessage userMessage,
        ChatMessage? aiUserMessage,
        bool forceFreshContext,
        bool suppressAssistantText,
        string? inProgressLabel,
        string? completionLabel)
    {
        CancelAnyCurrentResponse();
        messages.Add(userMessage);
        chatSuggestions?.Clear();
        if (chatInput is not null)
        {
            await chatInput.FocusAsync();
        }

        var responseText = new TextContent(inProgressLabel ?? "");
        currentResponseMessage = new ChatMessage(ChatRole.Assistant, [responseText]);
        currentResponseCancellation = new();
        var hadError = false;

        try
        {
            var requestUserMessage = aiUserMessage ?? userMessage;
            var requestMessages = forceFreshContext
                ? new List<ChatMessage> { messages.First(m => m.Role == ChatRole.System), requestUserMessage }
                : messages.Skip(statefulMessageCount).ToList();

            var requestOptions = forceFreshContext
                ? new ChatOptions { Tools = chatOptions.Tools }
                : chatOptions;

            await foreach (var update in ChatClient.GetStreamingResponseAsync(requestMessages, requestOptions, currentResponseCancellation.Token))
            {
                messages.AddMessages(update, filter: c => c is not TextContent);
                if (!suppressAssistantText)
                {
                    responseText.Text += update.Text;
                }
                if (!forceFreshContext)
                {
                    chatOptions.ConversationId = update.ConversationId;
                }
                if (currentResponseMessage is not null)
                {
                    ChatMessageItem.NotifyChanged(currentResponseMessage);
                }
            }
        }
        catch (OperationCanceledException)
        {
            hadError = true;
            responseText.Text += "\n\n[The response stream was canceled. Please try again.]";
        }
        catch (IOException)
        {
            hadError = true;
            responseText.Text += "\n\n[Network interruption while streaming. Please retry.]";
        }
        catch (Exception ex)
        {
            hadError = true;
            var message = ex.Message;
            if (message.Contains("No such host", StringComparison.OrdinalIgnoreCase)
                || message.Contains("NameResolution", StringComparison.OrdinalIgnoreCase))
            {
                message = "AI endpoint could not be reached. Check your endpoint DNS or network connection.";
            }
            if (message.Contains("tokens_limit_reached", StringComparison.OrdinalIgnoreCase)
                || message.Contains("Request body too large", StringComparison.OrdinalIgnoreCase))
            {
                message = "The request was too large for the model. I trimmed the context; please retry the action.";
            }
            responseText.Text += $"\n\n[Unexpected error: {message}]";
        }

        if (suppressAssistantText && !hadError)
        {
            responseText.Text = completionLabel ?? inProgressLabel ?? "Resume/CV generated.";
        }

        if (currentResponseMessage is not null)
        {
            messages.Add(currentResponseMessage);
        }
        if (!forceFreshContext)
        {
            statefulMessageCount = chatOptions.ConversationId is not null ? messages.Count : 0;
        }
        currentResponseMessage = null;
        chatSuggestions?.Update(messages);
    }

    private async Task ResetConversationAsync()
    {
        CancelAnyCurrentResponse();
        messages.Clear();
        messages.Add(new(ChatRole.System, GetSystemPrompt()));
        chatOptions.ConversationId = null;
        statefulMessageCount = 0;
        chatSuggestions?.Clear();
        if (chatInput is not null)
        {
            await chatInput.FocusAsync();
        }
    }

    private void CancelAnyCurrentResponse()
    {
        if (currentResponseMessage is not null) messages.Add(currentResponseMessage);
        currentResponseCancellation?.Cancel();
        currentResponseMessage = null;
    }

    [Description("Loads documents for search.")]
    private async Task LoadDocumentsAsync() => await Search.LoadDocumentsAsync();

    [Description("Searches for information.")]
    private async Task<IEnumerable<string>> SearchAsync(string searchPhrase, string? filenameFilter = null)
    {
        var results = await Search.SearchAsync(searchPhrase, filenameFilter, maxResults: 5);
        return results.Select(result => $"<result filename=\"{result.DocumentId}\">{result.Text}</result>");
    }

    private bool IsPromptReady => BuildPromptWarnings().Count == 0;
    private bool IsUploadReady => BuildUploadWarnings().Count == 0;

    private IReadOnlyList<string> PromptWarnings => promptAttempted ? BuildPromptWarnings() : Array.Empty<string>();
    private IReadOnlyList<string> UploadWarnings => uploadAttempted ? BuildUploadWarnings() : Array.Empty<string>();

    private List<string> BuildPromptWarnings()
    {
        var warnings = new List<string>();
        if (string.IsNullOrWhiteSpace(hrJobDescription))
        {
            warnings.Add("Prompt is required.");
        }
        if (!templateSelectionTouched)
        {
            warnings.Add("Choose a template to continue.");
        }
        return warnings;
    }

    private List<string> BuildUploadWarnings()
    {
        var warnings = new List<string>();
        if (string.IsNullOrWhiteSpace(uploadedResumeText))
        {
            warnings.Add("Upload a PDF resume so I can extract the content.");
        }
        if (string.IsNullOrWhiteSpace(uploadJobDescription))
        {
            warnings.Add("Prompt is required.");
        }
        if (!templateSelectionTouched)
        {
            warnings.Add("Choose a template to continue.");
        }
        return warnings;
    }

    private async Task ShowValidationAlertAsync(IReadOnlyList<string> warnings)
    {
        if (warnings.Count == 0)
        {
            return;
        }

        var message = "Please complete the following before submitting:\n- " + string.Join("\n- ", warnings);
        await JS.InvokeVoidAsync("alert", message);
    }

    private void AddLocalErrorMessage(Exception ex)
    {
        messages.Add(new(ChatRole.Assistant, $"[Error] {ex.Message}"));
        _ = InvokeAsync(StateHasChanged);
    }

    private bool HasExistingDraftData()
        => !string.IsNullOrWhiteSpace(CvDraftState.Draft.FullName)
           || !string.IsNullOrWhiteSpace(CvDraftState.Draft.Summary)
           || CvDraftState.Draft.Experiences.Count > 0
           || CvDraftState.Draft.Education.Count > 0
           || CvDraftState.Draft.Skills.Count > 0
           || CvDraftState.Draft.SkillGroups.Count > 0
           || CvDraftState.Draft.Projects.Count > 0
           || CvDraftState.Draft.Certifications.Count > 0;

    private static bool IndicatesNoExperience(string? text)
    {
        if (string.IsNullOrWhiteSpace(text))
        {
            return false;
        }

        var normalized = text.ToLowerInvariant();
        return normalized.Contains("no experience")
            || normalized.Contains("no prior experience")
            || normalized.Contains("fresher")
            || normalized.Contains("0 years")
            || normalized.Contains("0 year");
    }

    public void Dispose()
    {
        currentResponseCancellation?.Cancel();
        CvDraftState.OnChange -= HandleDraftChange;
    }
}
