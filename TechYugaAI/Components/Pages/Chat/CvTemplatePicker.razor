@using TechYugaAI.Services

<div class="cv-template-picker">
    @foreach (var template in Templates)
    {
        <label class="cv-template-option @(template.Id == SelectedTemplateId ? "selected" : "")">
            <input type="radio"
                   name="cv-template"
                   value="@template.Id"
                   checked="@(template.Id == SelectedTemplateId)"
                   @onchange="@(() => SelectedTemplateIdChanged.InvokeAsync(template.Id))" />
            <div class="cv-template-card @template.PreviewClass">
                <div class="cv-template-swatch" style="background:@template.AccentHex"></div>
                <div class="cv-template-meta">
                    <div class="cv-template-name">@template.Name</div>
                    <div class="cv-template-desc">@template.Description</div>
                </div>
            </div>
        </label>
    }
</div>

@code {
    [Parameter, EditorRequired]
    public required IReadOnlyList<CvTemplateDefinition> Templates { get; set; }

    [Parameter, EditorRequired]
    public required string SelectedTemplateId { get; set; }

    [Parameter]
    public EventCallback<string> SelectedTemplateIdChanged { get; set; }
}
